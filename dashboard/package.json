{
  "name": "claude-rpc-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "GUI editor for claude-rpc config — Electron popup for timing and rotation frames",
  "license": "MIT",
  "author": "Archer Simmons",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.archersimmons.claude-rpc-dashboard",
    "productName": "Claude RPC Dashboard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer.js"
    ],
    "asar": true,
    "win": {
      "target": "portable",
      "artifactName": "claude-rpc-dashboard.exe"
    },
    "portable": {
      "artifactName": "claude-rpc-dashboard.exe"
    }
  }
}
